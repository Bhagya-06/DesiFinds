# ============================================================================
# DesiFinds - Environment Variables Example Configuration
# Copy this file to '.env' and fill in your keys.
# ============================================================================

# 1. OpenAI Configuration (Used for API fallbacks and ingestion scripts)
# Note: The web app primarily accepts API keys dynamically entered in the UI.
# Setting this here provides a default fallback for backend requests and CLI tools.
export OPENAI_API_KEY=<your-openai-api-key>

# 2. LangSmith Tracing Configuration (Optional - set to true to monitor agents)
export LANGSMITH_TRACING=true
export LANGSMITH_ENDPOINT=https://api.smith.langchain.com
export LANGSMITH_API_KEY=<your-langsmith-api-key>
export LANGSMITH_PROJECT="DesiFinds"

